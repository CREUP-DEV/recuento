# Deployment target (required by deploy.sh)
VPS_HOST=dockeruser@your-vps-ip-or-hostname
REMOTE_DIR=/opt/recuento

# Optional GHCR login used by deploy.sh for local push
GHCR_USERNAME=your-github-username
GHCR_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Optional image overrides
# IMAGE_NAME=ghcr.io/CREUP-DEV/recuento
# IMAGE_TAG=<git-sha-or-custom-tag>
# IMAGE=ghcr.io/CREUP-DEV/recuento:<tag>

# Optional deploy settings
DOCKER_PLATFORM=linux/amd64
APPLY_MIGRATIONS_ON_DEPLOY=true
APP_PORT=3000
APP_BANNERS_DIR=./data/banners

# Application
# Runtime site origin for server-side URL generation.
NUXT_SITE_URL=http://localhost:3000
# Shared timezone used by app containers and Postgres runtime.
TZ=Europe/Madrid
# Master secret — used for Better Auth sessions.
# Generate with: openssl rand -base64 32
APP_SECRET=replace-with-a-long-random-secret

# Admin access and OAuth
# ADMIN_EMAILS: comma-separated list of emails that always have admin access.
ADMIN_EMAILS=admin@example.com
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# PostgreSQL
POSTGRES_USER=recuento
POSTGRES_PASSWORD=change-me
POSTGRES_DB=recuento
POSTGRES_PORT=5433

# Database connection (used directly by migration scripts and DB pool).
DATABASE_URL="postgresql://recuento:change-me@localhost:5433/recuento?schema=public"

# Maximum number of connections in the pg connection pool.
DATABASE_MAX_CONNECTIONS=10

# Local tooling
ADMINER_PORT=8089

# Analytics
NUXT_UMAMI_HOST=https://umami.example.com
NUXT_UMAMI_ID=00000000-0000-0000-0000-000000000000
